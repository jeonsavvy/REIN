# Local mode is deterministic and never signs or broadcasts a blockchain transaction.
PROOFBUY_MODE=demo
PROOFBUY_STORAGE=memory
# "fixture" is deterministic for local reproduction. Use "live" for the real APIs.
PROOFBUY_UPSTREAM_MODE=fixture
APP_BASE_URL=http://localhost:3000

# Required for live Gemini 3.5 Flash through Vertex AI.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=true

# Required for live x402 Solana Devnet settlement.
# Store this value in Secret Manager in Cloud Run; never commit it.
SVM_PRIVATE_KEY=
SVM_PAY_TO=
X402_FACILITATOR_URL=https://x402.org/facilitator

# Production storage. Application Default Credentials are used; no JSON key file is required.
FIRESTORE_DATABASE_ID=(default)

# Optional upstream identification and rate-limit improvement.
GITHUB_TOKEN=
